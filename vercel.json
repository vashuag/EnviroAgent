{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/proxy/:path*",
      "destination": "https://your-cloudrun-url.run.app/api/:path*"
    }
  ]
}
